#!/usr/bin/env bash
set -euo pipefail

repo_root=$(git rev-parse --show-toplevel 2>/dev/null || echo ".")
cd "$repo_root"

last_tag=$(git describe --tags --abbrev=0 2>/dev/null || echo "")

if [ -z "$last_tag" ]; then
  commits=$(git log --pretty=format:"%s")
else
  commits=$(git log "${last_tag}..HEAD" --pretty=format:"%s")
fi

added=()
fixed=()
changed=()
removed=()

while IFS= read -r commit_msg; do
  type=$(echo "$commit_msg" | grep -oE '^[a-zA-Z]+' | head -1 | tr '[:upper:]' '[:lower:]')
  case "$type" in
    feat|feature|add) added+=("$commit_msg") ;;
    fix|bug|patch) fixed+=("$commit_msg") ;;
    refactor|improve|update|style|chore|ci|build|test) changed+=("$commit_msg") ;;
    remove|delete|drop|break) removed+=("$commit_msg") ;;
    *) changed+=("$commit_msg") ;;
  esac
done <<< "$commits"

output="## [Unreleased]\n\n"
if [ ${#added[@]} -gt 0 ]; then
  output+="### Added\n"
  for msg in "${added[@]}"; do
    output+="- $msg\n"
  done
  output+="\n"
fi
if [ ${#fixed[@]} -gt 0 ]; then
  output+="### Fixed\n"
  for msg in "${fixed[@]}"; do
    output+="- $msg\n"
  done
  output+="\n"
fi
if [ ${#changed[@]} -gt 0 ]; then
  output+="### Changed\n"
  for msg in "${changed[@]}"; do
    output+="- $msg\n"
  done
  output+="\n"
fi
if [ ${#removed[@]} -gt 0 ]; then
  output+="### Removed\n"
  for msg in "${removed[@]}"; do
    output+="- $msg\n"
  done
  output+="\n"
fi

echo -e "$output"
